{
  "$schema": "https://raw.githubusercontent.com/nicezheng/tauri-v2-schema/refs/heads/master/tauri.conf.json",
  "productName": "Bili2Insight",
  "version": "0.1.0",
  "identifier": "com.bomu.bili2insight",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Bili2Insight - B站视频观点提炼",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "dialog": {},
    "fs": {
      "scope": {
        "allow": [
          "$APPDATA/**",
          "$DOWNLOAD/**",
          "$DESKTOP/**",
          "$TEMP/**"
        ]
      }
    },
    "shell": {
      "scope": [
        {
          "name": "python",
          "cmd": "python",
          "args": true
        },
        {
          "name": "ffmpeg",
          "cmd": "ffmpeg",
          "args": true
        }
      ]
    },
    "clipboard-manager": {}
  }
}
