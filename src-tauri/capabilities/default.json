{
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "shell:default",
    "process:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "core:event:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bili_worker",
          "sidecar": true,
          "args": true
        },
        {
          "name": "asr_worker",
          "sidecar": true,
          "args": true
        },
        {
          "name": "ffmpeg",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "bili_worker",
          "sidecar": true,
          "args": true
        },
        {
          "name": "asr_worker",
          "sidecar": true,
          "args": true
        },
        {
          "name": "ffmpeg",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}